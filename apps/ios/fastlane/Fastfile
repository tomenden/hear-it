default_platform :ios

# Fastlane configuration for Hear It iOS
#
# Lanes:
#   beta   — build for ad-hoc distribution and upload to Firebase App Distribution
#
# Required environment variables (set as GitHub Actions secrets):
#   MATCH_PASSWORD              — Fastlane Match passphrase
#   MATCH_GIT_URL               — Git repo URL that stores certificates + profiles
#   APP_STORE_CONNECT_API_KEY   — JSON string from App Store Connect (for signing)
#   FIREBASE_APP_ID             — Firebase iOS App ID (1:xxx:ios:yyy)
#   FIREBASE_TOKEN              — Firebase CLI token
#   HEAR_IT_API_URL             — Render preview/production URL to embed as the default API base URL
#   BUILD_NUMBER                — e.g. GitHub Actions run number
#   GIT_BRANCH                  — branch name, used as the release notes label

platform :ios do
  desc "Build and distribute a branch preview to Firebase App Distribution"
  lane :beta do
    # --- Auth ---
    api_key = app_store_connect_api_key(
      key_id:       JSON.parse(ENV["APP_STORE_CONNECT_API_KEY"])["key_id"],
      issuer_id:    JSON.parse(ENV["APP_STORE_CONNECT_API_KEY"])["issuer_id"],
      key_content:  JSON.parse(ENV["APP_STORE_CONNECT_API_KEY"])["key"],
      is_key_content_base64: false
    )

    # --- Code signing via Match (ad-hoc profile) ---
    match(
      type:           "adhoc",
      app_identifier: "com.tome.hearit",
      git_url:        ENV["MATCH_GIT_URL"],
      password:       ENV["MATCH_PASSWORD"],
      api_key:        api_key,
      readonly:       true
    )

    # --- Bump build number ---
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    "HearIt.xcodeproj"
    )

    # --- Inject the Render preview URL as the default API base URL ---
    # Passed as an xcarg so the compiled Info.plist contains the right URL
    # without modifying any committed files.
    hear_it_api_url = ENV["HEAR_IT_API_URL"] || "https://hear-it.onrender.com"

    # --- Build ---
    gym(
      scheme:          "HearIt",
      configuration:   "Release",
      export_method:   "ad-hoc",
      xcargs:          "HEAR_IT_API_BASE_URL='#{hear_it_api_url}'",
      output_directory: "./build",
      output_name:     "HearIt.ipa",
      clean:           true
    )

    # --- Distribute ---
    branch = ENV["GIT_BRANCH"] || "unknown branch"
    firebase_app_distribution(
      app:             ENV["FIREBASE_APP_ID"],
      firebase_cli_token: ENV["FIREBASE_TOKEN"],
      ipa_path:        "./build/HearIt.ipa",
      groups:          "testers",
      release_notes:   "Branch: #{branch}\nAPI: #{hear_it_api_url}"
    )
  end
end
